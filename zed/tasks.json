[
  {
    "label": "Start Typst Watch",
    "command": "sh",
    "args": [
      "-c",
      "pkill -f 'typst watch.*$ZED_FILENAME' 2>/dev/null; typst watch '$ZED_FILE' --root='$ZED_WORKTREE_ROOT'"
    ],
    "use_new_terminal": true
  },
  {
    "label": "Open PDF in Skim",
    "command": "open",
    "args": ["-a", "Skim", "$ZED_DIRNAME/$ZED_STEM.pdf"],
    "use_new_terminal": false
  }
]
